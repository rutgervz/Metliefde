# Met Liefde Facturen — omgevingsvariabelen
# Kopieer naar .env.local voor lokaal (niet in fase 1 van toepassing — wij testen via Vercel-previews).
# Zet deze waarden in Vercel onder Project Settings → Environment Variables.

# Supabase — te vinden in Supabase dashboard onder Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — voor Claude Haiku fallback in de extractie-laag (stap 6).
ANTHROPIC_API_KEY=

# Google OAuth plus Gmail en Drive scopes (stap 5).
# Nog niet nodig voor stap 1. Aanmaken in Google Cloud Console wanneer we bij stap 5 zijn.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Whitelist van toegestane e-mailadressen (comma-separated) voor stap 2.
# Voorbeeld: rutger@example.com,annelie@example.com
ALLOWED_EMAILS=
