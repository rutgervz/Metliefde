# Met Liefde — omgevingsvariabelen
# Zet deze waarden in Vercel onder Project Settings → Environment Variables.
# Niet in Git committen als je ze lokaal invult (.env.local is gitignored).

# Supabase — Project Settings → API in je Supabase-dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Whitelist voor inloggen (Stap 2). Comma-separated. Alleen deze adressen mogen inloggen.
# Voorbeeld: rutger@example.com,annelie@example.com
ALLOWED_EMAILS=

# Anthropic — voor Claude Haiku fallback in de extractie-laag (Stap 6).
ANTHROPIC_API_KEY=

# Google OAuth voor mailbox-koppeling (Stap 5).
# Hergebruik dezelfde OAuth-client als die voor Supabase Auth, maar dan met
# Gmail-scopes ingeschakeld in de OAuth consent screen en met de extra
# redirect URI https://<APP_URL>/api/mailbox/callback in de client whitelist.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Publieke basis-URL van de app. Wordt gebruikt om de mailbox-callback-URL
# te bouwen. Default in code is https://metliefde.vercel.app.
NEXT_PUBLIC_APP_URL=https://metliefde.vercel.app

# Geheime sleutel die de Vercel cron meegeeft als Bearer-token bij het
# aanroepen van /api/cron/sync-mailboxes. Genereer een random string en
# zet hem zowel als environment variable als bij de cron-config.
CRON_SECRET=
